{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SiimpliGraphIt",
  "version": "0.3.65",
  "identifier": "com.siimpl.siimpli-graph-it",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SiimpliGraphIt",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self'; object-src 'none'; frame-ancestors 'none'",
      "freezePrototype": false
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkyREY4Q0I5NzAxREM0OTAKUldTUXhCMXd1WXpma25oblJFM1krUURRQnIwSnM1TjRsVVp4ZUsyV3IzNEtYOStUNTNPOWV6ZUEK",
      "endpoints": [
        "https://github.com/harisonsharp/siimpli-graph-it/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "windows": {
        "installerArgs": ["/passive"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}